@inherits LayoutComponentBase
@inject IAuthService Auth
@inject NavigationManager Nav

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Small" />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary" Dense="false">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Edge="Edge.Start" OnClick="() => _open = !_open" />
        <MudText Typo="Typo.h6" Class="ml-2 d-none d-sm-flex">
            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Class="mr-1" Style="vertical-align:middle" />
            CashFlow
        </MudText>
        <MudSpacer />
        <MudChip T="string" Icon="@Icons.Material.Filled.Person" Color="Color.Secondary"
                 Size="Size.Small" Class="d-none d-sm-flex">@_email</MudChip>
        <MudTooltip Text="Sair">
            <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                           OnClick="LogoutAsync" />
        </MudTooltip>
    </MudAppBar>

    <MudDrawer @bind-Open="_open" ClipMode="DrawerClipMode.Always"
               Elevation="2" Variant="DrawerVariant.Responsive" Width="220px">
        <MudDrawerHeader Class="pt-4 pb-2">
            <MudText Typo="Typo.subtitle2" Color="Color.Primary"><b>NAVEGAÇÃO</b></MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavLink Href="/transactions"
                        Icon="@Icons.Material.Filled.SwapHoriz">Lançamentos</MudNavLink>
            <MudNavLink Href="/consolidation"
                        Icon="@Icons.Material.Filled.BarChart">Consolidado</MudNavLink>
            <MudNavLink Href="/categories"
                        Icon="@Icons.Material.Filled.Category">Categorias</MudNavLink>
            <MudDivider Class="my-2" />
            <MudNavLink Icon="@Icons.Material.Filled.Logout"
                        OnClick="LogoutAsync">Sair</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4 pa-sm-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool   _open  = true;
    private string _email = string.Empty;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary          = "#1565C0",
            PrimaryDarken    = "#003c8f",
            PrimaryLighten   = "#5e92f3",
            Secondary        = "#2E7D32",
            SecondaryDarken  = "#005005",
            SecondaryLighten = "#60ad5e",
            AppbarBackground = "#1565C0",
            Background       = "#F0F4F8",
            Surface          = "#FFFFFF",
            DrawerBackground = "#FAFAFA",
            DrawerText       = "#212121",
        }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _email = await Auth.GetUserEmailAsync() ?? string.Empty;
        StateHasChanged();
    }

    private async Task LogoutAsync()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login", forceLoad: true);
    }
}
