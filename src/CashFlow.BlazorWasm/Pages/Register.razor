@page "/register"
@layout EmptyLayout
@inject IAuthService Auth
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.False"
              Style="min-height:100vh;background:linear-gradient(135deg,#1565C0 0%,#0D47A1 100%)"
              Class="d-flex align-center justify-center">

    <MudPaper Elevation="8" Class="pa-8 pa-sm-10" Style="width:100%;max-width:420px;border-radius:16px">

        <div class="d-flex flex-column align-center mb-6">
            <MudAvatar Style="background:#2E7D32;width:64px;height:64px;margin-bottom:12px">
                <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Style="font-size:32px;color:white" />
            </MudAvatar>
            <MudText Typo="Typo.h5" Color="Color.Primary"><b>Criar conta</b></MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                Comece a controlar seu financeiro
            </MudText>
        </div>

        <MudTextField @bind-Value="_fullName" Label="Nome completo" Variant="Variant.Outlined"
                      FullWidth="true" Class="mb-3"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person" />

        <MudTextField @bind-Value="_email" Label="E-mail" Variant="Variant.Outlined"
                      InputType="InputType.Email" FullWidth="true" Class="mb-3"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />

        <MudTextField @bind-Value="_password" Label="Senha" Variant="Variant.Outlined"
                      InputType="@_pwdType" FullWidth="true" Class="mb-3"
                      Adornment="Adornment.End" AdornmentIcon="@_pwdIcon"
                      OnAdornmentClick="TogglePwd" HelperText="Mínimo 8 caracteres, 1 maiúscula e 1 número" />

        <MudTextField @bind-Value="_confirm" Label="Confirmar senha" Variant="Variant.Outlined"
                      InputType="InputType.Password" FullWidth="true" Class="mb-5"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock"
                      Error="@(_confirm.Length > 0 && _confirm != _password)"
                      ErrorText="Senhas não conferem" />

        <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true"
                   Size="Size.Large" OnClick="HandleRegisterAsync" Disabled="_loading"
                   Style="border-radius:8px;padding:12px" Class="mb-4">
            @if (_loading)
            { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            <span>@(_loading ? "Cadastrando..." : "Criar conta")</span>
        </MudButton>

        <MudText Align="Align.Center" Typo="Typo.body2">
            Já tem conta?
            <MudLink Href="/login" Color="Color.Primary"><b>Entrar</b></MudLink>
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    private string _fullName = string.Empty;
    private string _email    = string.Empty;
    private string _password = string.Empty;
    private string _confirm  = string.Empty;
    private bool   _loading;
    private InputType _pwdType = InputType.Password;
    private string    _pwdIcon = Icons.Material.Filled.VisibilityOff;

    private void TogglePwd()
    {
        if (_pwdType == InputType.Password)
            { _pwdType = InputType.Text;     _pwdIcon = Icons.Material.Filled.Visibility; }
        else
            { _pwdType = InputType.Password; _pwdIcon = Icons.Material.Filled.VisibilityOff; }
    }

    private async Task HandleRegisterAsync()
    {
        if (string.IsNullOrWhiteSpace(_fullName) || string.IsNullOrWhiteSpace(_email) ||
            string.IsNullOrWhiteSpace(_password))
        { Snackbar.Add("Preencha todos os campos.", Severity.Warning); return; }

        if (_password != _confirm)
        { Snackbar.Add("Senhas não conferem.", Severity.Warning); return; }

        if (_password.Length < 8)
        { Snackbar.Add("Senha deve ter pelo menos 8 caracteres.", Severity.Warning); return; }

        _loading = true;
        var (ok, err) = await Auth.RegisterAsync(
            new RegisterRequest(_email, _fullName, _password, _confirm));
        _loading = false;

        if (ok)
        {
            Snackbar.Add("Conta criada! Faça login.", Severity.Success);
            Nav.NavigateTo("/login");
        }
        else
            Snackbar.Add(err ?? "Erro ao criar conta.", Severity.Error);
    }
}
