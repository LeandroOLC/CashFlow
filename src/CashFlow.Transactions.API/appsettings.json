{
  "ConnectionStrings": {
    "TransactionDb": "Server=(localdb)\\mssqllocaldb;Database=TransactionDb;Trusted_Connection=True;"
  },
  "Jwt": {
    "Secret": "CashFlowSuperSecretKey2025MustBe32CharsLong!",
    "Issuer": "CashFlow.Auth",
    "Audience": "CashFlow.Services",
    "ExpiresInHours": "1"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": "5672",
    "Username": "guest",
    "Password": "guest"
  },
  "Swagger": {
    "Enabled": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Debug",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Properties": {
      "Environment": "Development"
    }
  }
}
