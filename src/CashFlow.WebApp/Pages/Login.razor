@page "/login"
@layout EmptyLayout
@inject IAuthService Auth
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.False"
              Style="min-height:100vh;background:linear-gradient(135deg,#1565C0,#0D47A1)"
              Class="d-flex align-center justify-center">
    <MudPaper Elevation="8" Class="pa-8" Style="width:100%;max-width:400px;border-radius:16px">
        <div class="d-flex flex-column align-center mb-6">
            <MudAvatar Style="background:#1565C0;width:60px;height:60px;margin-bottom:12px">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Style="font-size:30px;color:white" />
            </MudAvatar>
            <MudText Typo="Typo.h5" Color="Color.Primary"><b>CashFlow</b></MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Controle financeiro</MudText>
        </div>

        <MudTextField @bind-Value="_email" Label="E-mail" Variant="Variant.Outlined"
                      InputType="InputType.Email" FullWidth="true" Class="mb-3"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email"
                      @onkeydown="OnKeyDown" />

        <MudTextField @bind-Value="_pwd" Label="Senha" Variant="Variant.Outlined"
                      InputType="@_pwdType" FullWidth="true" Class="mb-5"
                      Adornment="Adornment.End" AdornmentIcon="@_pwdIcon"
                      OnAdornmentClick="TogglePwd"
                      @onkeydown="OnKeyDown" />

        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                   Size="Size.Large" OnClick="DoLoginAsync" Disabled="_busy" Class="mb-4">
            @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            @(_busy ? "Entrando..." : "Entrar")
        </MudButton>

        <MudText Align="Align.Center" Typo="Typo.body2">
            Sem conta? <MudLink Href="/register" Color="Color.Primary"><b>Cadastre-se</b></MudLink>
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    private string    _email   = string.Empty;
    private string    _pwd     = string.Empty;
    private bool      _busy;
    private InputType _pwdType = InputType.Password;
    private string    _pwdIcon = Icons.Material.Filled.VisibilityOff;

    private void TogglePwd()
    {
        if (_pwdType == InputType.Password) { _pwdType = InputType.Text;     _pwdIcon = Icons.Material.Filled.Visibility; }
        else                                { _pwdType = InputType.Password; _pwdIcon = Icons.Material.Filled.VisibilityOff; }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    { if (e.Key == "Enter") await DoLoginAsync(); }

    private async Task DoLoginAsync()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_pwd))
        { Snackbar.Add("Preencha e-mail e senha.", Severity.Warning); return; }

        _busy = true;
        var (ok, err) = await Auth.LoginAsync(new LoginRequest(_email, _pwd));
        _busy = false;

        if (ok) Nav.NavigateTo("/", forceLoad: true);
        else    Snackbar.Add(err ?? "Credenciais inválidas.", Severity.Error);
    }
}
