@page "/"
@inject ITransactionService   TxSvc
@inject IConsolidationService ConSvc
@inject NavigationManager     Nav

<MudText Typo="Typo.h5" Class="mb-1"><b>Dashboard</b></MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-5">
    @DateTime.Today.ToString("MMMM/yyyy", _ptBR)
</MudText>

@if (_loading)
{
    <div class="d-flex justify-center mt-16">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
    </div>
}
else
{
    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-5 rounded-lg" Style="border-left:4px solid #2E7D32">
                <MudText Typo="Typo.overline" Color="Color.Success">RECEITAS (MÊS)</MudText>
                <MudText Typo="Typo.h5" Style="color:#2E7D32;font-weight:700">@_credits.ToString("C2", _ptBR)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-5 rounded-lg" Style="border-left:4px solid #C62828">
                <MudText Typo="Typo.overline" Color="Color.Error">DESPESAS (MÊS)</MudText>
                <MudText Typo="Typo.h5" Style="color:#C62828;font-weight:700">@_debits.ToString("C2", _ptBR)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-5 rounded-lg"
                      Style="@($"border-left:4px solid {(_balance >= 0 ? "#1565C0" : "#E65100")}")">
                <MudText Typo="Typo.overline">SALDO DO MÊS</MudText>
                <MudText Typo="Typo.h5"
                         Style="@($"font-weight:700;color:{(_balance >= 0 ? "#1565C0" : "#E65100")}")">
                    @_balance.ToString("C2", _ptBR)
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-5 rounded-lg" Style="border-left:4px solid #6A1B9A">
                <MudText Typo="Typo.overline" Style="color:#6A1B9A">ÚLTIMO CONSOLIDADO</MudText>
                @if (_latest is not null)
                {
                    <MudText Typo="Typo.h5" Style="font-weight:700;color:#6A1B9A">
                        @_latest.FinalBalance.ToString("C2", _ptBR)
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_latest.Date.ToString("dd/MM/yyyy")</MudText>
                }
                else { <MudText Typo="Typo.h6" Color="Color.Secondary">—</MudText> }
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="2" Class="rounded-lg">
        <div class="d-flex align-center justify-space-between pa-4 pb-2">
            <MudText Typo="Typo.subtitle1"><b>Últimos Lançamentos</b></MudText>
            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick='() => Nav.NavigateTo("/transactions")'>Ver todos</MudButton>
        </div>
        <MudTable Items="_recent" Dense="true" Hover="true" Elevation="0" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Data</MudTh><MudTh>Descrição</MudTh><MudTh>Tipo</MudTh>
                <MudTh Style="text-align:right">Valor</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Data">@context.Date.ToString("dd/MM/yyyy")</MudTd>
                <MudTd DataLabel="Descrição">
                    <MudText Style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                             Title="@context.Description">@context.Description</MudText>
                </MudTd>
                <MudTd DataLabel="Tipo">
                    <MudChip T="string" Size="Size.Small"
                             Color="@(context.Type=="Credit" ? Color.Success : Color.Error)"
                             Variant="Variant.Outlined">
                        @(context.Type == "Credit" ? "Receita" : "Despesa")
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Valor" Style="text-align:right">
                    <MudText Style="@($"font-weight:600;color:{(context.Type=="Credit"?"#2E7D32":"#C62828")}")">
                        @(context.Type=="Credit"?"+":"-")@context.Amount.ToString("C2",_ptBR)
                    </MudText>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Align="Align.Center" Class="pa-6" Color="Color.Secondary">
                    Nenhum lançamento encontrado
                </MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
}

@code {
    private bool   _loading = true;
    private bool   _done;
    private DailyBalanceDto?     _latest;
    private List<TransactionDto> _recent  = [];
    private decimal _credits, _debits, _balance;

    private static readonly System.Globalization.CultureInfo _ptBR =
        System.Globalization.CultureInfo.GetCultureInfo("pt-BR");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _done) return;
        _done = true;

        var now   = DateTime.Today;
        var first = new DateTime(now.Year, now.Month, 1);
        var last  = first.AddMonths(1).AddDays(-1);

        var t1 = ConSvc.GetLatestAsync();
        var t2 = ConSvc.GetByPeriodAsync(first, last, 1, 31);
        var t3 = TxSvc.GetPagedAsync(1, 8);
        await Task.WhenAll(t1, t2, t3);

        _latest  = t1.Result;
        var per  = t2.Result?.Items ?? [];
        _credits = per.Sum(b => b.TotalCredits);
        _debits  = per.Sum(b => b.TotalDebits);
        _balance = _credits - _debits;
        _recent  = t3.Result?.Items.ToList() ?? [];

        _loading = false;
        StateHasChanged();
    }
}
