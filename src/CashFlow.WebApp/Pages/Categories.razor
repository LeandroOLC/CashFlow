@page "/categories"
@inject ITransactionService TxSvc

<MudText Typo="Typo.h5" Class="mb-1"><b>Categorias</b></MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Categorias disponíveis para lançamentos
</MudText>

@if (_loading)
{
    <div class="d-flex justify-center mt-12">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
    </div>
}
else if (!_cats.Any())
{
    <div class="d-flex flex-column align-center mt-12">
        <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Large" Color="Color.Secondary" />
        <MudText Class="mt-2" Color="Color.Secondary">Nenhuma categoria encontrada</MudText>
    </div>
}
else
{
    <MudGrid>
        @foreach (var cat in _cats)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg d-flex align-center gap-3"
                          Style="border-left:4px solid #1565C0">
                    <MudAvatar Color="Color.Primary" Size="Size.Medium">
                        <MudIcon Icon="@Icons.Material.Filled.Label" />
                    </MudAvatar>
                    <div style="flex:1;min-width:0">
                        <MudText Typo="Typo.subtitle2"><b>@cat.Name</b></MudText>
                        @if (!string.IsNullOrEmpty(cat.Description))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary"
                                     Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                                @cat.Description
                            </MudText>
                        }
                    </div>
                    <MudChip T="string" Size="Size.Small"
                             Color="@(cat.IsActive ? Color.Success : Color.Default)">
                        @(cat.IsActive ? "Ativa" : "Inativa")
                    </MudChip>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private bool _loading = true;
    private bool _done;
    private List<TransactionCategoryDto> _cats = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _done) return;
        _done = true;
        var r = await TxSvc.GetCategoriesAsync();
        _cats = r.OrderBy(c => c.Name).ToList();
        _loading = false;
        StateHasChanged();
    }
}
